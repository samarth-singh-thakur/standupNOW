<?xml version="1.0" encoding="utf-8"?>
<!-- Date header for timeline grouping -->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:paddingTop="@dimen/space_md"
    android:paddingBottom="@dimen/space_sm"
    android:paddingStart="@dimen/space_md"
    android:paddingEnd="@dimen/space_md">

    <TextView
        android:id="@+id/date_header_text"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:fontFamily="monospace"
        android:text="Today"
        android:textColor="@color/color_gold"
        android:textSize="18sp"
        android:textStyle="bold" />

    <View
        android:layout_width="match_parent"
        android:layout_height="2dp"
        android:layout_marginTop="@dimen/space_xs"
        android:background="@color/color_gold"
        android:alpha="0.3" />

</LinearLayout>

