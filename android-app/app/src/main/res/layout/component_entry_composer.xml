<?xml version="1.0" encoding="utf-8"?>
<!-- EntryComposer Component: Primary interaction surface for creating entries -->
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/entry_composer"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_pure_black"
    android:animateLayoutChanges="true">

    <!-- Centered Compact Composer Box -->
    <LinearLayout
        android:id="@+id/composer_container"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_centerInParent="true"
        android:layout_marginStart="24dp"
        android:layout_marginEnd="24dp"
        android:orientation="vertical"
        android:background="@drawable/bg_input_section"
        android:animateLayoutChanges="true">

        <!-- Top Action Bar -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:padding="8dp"
            android:gravity="end">

            <!-- Delete Draft Button -->
            <ImageButton
                android:id="@+id/delete_draft_button"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:src="@android:drawable/ic_menu_delete"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:contentDescription="Delete draft"
                android:tint="@color/color_error"
                android:layout_marginEnd="8dp"
                android:visibility="gone" />

            <!-- Save Button -->
            <ImageButton
                android:id="@+id/save_entry_button"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:src="@android:drawable/ic_menu_save"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:contentDescription="Save entry"
                android:tint="@color/gold_accent"
                android:visibility="gone" />

        </LinearLayout>

        <!-- Entry Input with fixed height and scrolling -->
        <EditText
            android:id="@+id/composer_input"
            android:layout_width="match_parent"
            android:layout_height="200dp"
            android:hint="What's on your mind?"
            android:textColorHint="#80FFFFFF"
            android:textColor="@android:color/white"
            android:textSize="16sp"
            android:fontFamily="sans-serif"
            android:gravity="top|start"
            android:padding="16dp"
            android:background="@android:color/transparent"
            android:inputType="textMultiLine|textCapSentences"
            android:scrollbars="vertical"
            android:overScrollMode="always"
            android:scrollbarStyle="insideInset" />

    </LinearLayout>

</RelativeLayout>

