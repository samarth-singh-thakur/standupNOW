<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_medium"
    app:layout_behavior="@string/appbar_scrolling_view_behavior">

    <!-- Quick Jot Down Area -->
    <LinearLayout
        android:id="@+id/quick_jot_container"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_margin="@dimen/space_md"
        android:orientation="vertical"
        android:background="@drawable/bg_quick_jot_glow"
        android:padding="@dimen/space_lg"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <!-- Header -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="@dimen/space_md">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="✍️"
                android:textSize="24sp"
                android:layout_marginEnd="@dimen/space_sm" />

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="QUICK JOT DOWN YOUR PROGRESS"
                android:textColor="@color/color_gold"
                android:textSize="16sp"
                android:textStyle="bold"
                android:fontFamily="monospace" />

        </LinearLayout>

        <!-- Title -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="QUICK CHECKIN"
            android:textColor="@color/color_gold"
            android:textSize="20sp"
            android:textStyle="bold"
            android:fontFamily="monospace"
            android:layout_marginBottom="@dimen/space_md" />

        <!-- Input Area -->
        <EditText
            android:id="@+id/quick_jot_input"
            android:layout_width="match_parent"
            android:layout_height="200dp"
            android:hint="Type here and hit Save or press Ctrl+Enter..."
            android:textColorHint="#808080"
            android:textColor="@color/text_primary"
            android:fontFamily="monospace"
            android:textSize="16sp"
            android:background="@color/bg_pure_black"
            android:padding="@dimen/space_md"
            android:gravity="top|start"
            android:inputType="textMultiLine|textCapSentences"
            android:imeOptions="actionDone"
            android:maxLines="10"
            android:scrollbars="vertical" />

        <!-- Save Button -->
        <Button
            android:id="@+id/quick_jot_save"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="end"
            android:layout_marginTop="@dimen/space_md"
            android:text="Save"
            android:textColor="@color/bg_pure_black"
            android:backgroundTint="@color/color_gold"
            android:paddingStart="@dimen/space_xl"
            android:paddingEnd="@dimen/space_xl"
            android:fontFamily="monospace"
            android:textStyle="bold" />

    </LinearLayout>

    <!-- Search Bar -->
    <androidx.cardview.widget.CardView
        android:id="@+id/search_card"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_margin="@dimen/space_md"
        app:cardBackgroundColor="@color/bg_dark"
        app:cardCornerRadius="@dimen/radius_md"
        app:cardElevation="2dp"
        app:layout_constraintTop_toBottomOf="@id/quick_jot_container"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:padding="@dimen/space_sm"
            android:gravity="center_vertical">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="🔍"
                android:textSize="20sp"
                android:layout_marginEnd="@dimen/space_sm" />

            <EditText
                android:id="@+id/search_input"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:hint="Search your wins..."
                android:textColorHint="@color/text_secondary"
                android:textColor="@color/text_primary"
                android:fontFamily="monospace"
                android:background="@android:color/transparent"
                android:inputType="text"
                android:imeOptions="actionSearch"
                android:maxLines="1" />

        </LinearLayout>

    </androidx.cardview.widget.CardView>

    <!-- Filter Chips -->
    <HorizontalScrollView
        android:id="@+id/filter_chips_scroll"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:scrollbars="none"
        android:paddingStart="@dimen/space_md"
        android:paddingEnd="@dimen/space_md"
        android:paddingTop="@dimen/space_xs"
        android:paddingBottom="@dimen/space_xs"
        app:layout_constraintTop_toBottomOf="@id/search_card"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <com.google.android.material.chip.Chip
                android:id="@+id/chip_all"
                style="@style/Widget.Material3.Chip.Filter"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="All Entries"
                android:checked="true"
                android:layout_marginEnd="@dimen/space_xs" />

            <com.google.android.material.chip.Chip
                android:id="@+id/chip_today"
                style="@style/Widget.Material3.Chip.Filter"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Today"
                android:layout_marginEnd="@dimen/space_xs" />

            <com.google.android.material.chip.Chip
                android:id="@+id/chip_yesterday"
                style="@style/Widget.Material3.Chip.Filter"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Yesterday"
                android:layout_marginEnd="@dimen/space_xs" />

            <com.google.android.material.chip.Chip
                android:id="@+id/chip_this_week"
                style="@style/Widget.Material3.Chip.Filter"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="This Week"
                android:layout_marginEnd="@dimen/space_xs" />

            <com.google.android.material.chip.Chip
                android:id="@+id/chip_custom_range"
                style="@style/Widget.Material3.Chip.Filter"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Custom Date Range..." />

        </LinearLayout>

    </HorizontalScrollView>

    <TextView
        android:id="@+id/empty_text"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:fontFamily="monospace"
        android:text="No items yet.\nTap the + button to add one!"
        android:textAlignment="center"
        android:textColor="@color/text_secondary"
        android:textSize="@dimen/font_size_h3_small"
        android:lineSpacingMultiplier="1.6"
        android:paddingStart="@dimen/space_2xl"
        android:paddingEnd="@dimen/space_2xl"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/filter_chips_scroll" />

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/recycler_view"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:background="@color/bg_medium"
        android:clipToPadding="false"
        android:padding="@dimen/space_sm"
        app:layout_constraintTop_toBottomOf="@id/filter_chips_scroll"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layoutManager="androidx.recyclerview.widget.LinearLayoutManager"
        tools:listitem="@android:layout/simple_list_item_1" />

</androidx.constraintlayout.widget.ConstraintLayout>

